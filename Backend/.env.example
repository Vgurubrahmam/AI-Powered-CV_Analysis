# =============================================================================
#  ATS Platform — Environment Variables Reference
#  Copy to .env and fill in real values. Never commit .env to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
APP_URL=http://localhost:8000
DEBUG=true
SECRET_KEY=change-me-to-32-chars-random

# ---------------------------------------------------------------------------
# PostgreSQL — Supabase (pooler connection recommended)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# LLM — NVIDIA AI (primary provider)
# Get free API key at: https://build.nvidia.com
# ---------------------------------------------------------------------------
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_SMART_MODEL=meta/llama-3.1-70b-instruct

# ---------------------------------------------------------------------------
# LLM — OpenRouter (fallback, optional)
# Get free API key at: https://openrouter.ai
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemma-3-27b-it:free
OPENROUTER_FAST_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_SMART_MODEL=deepseek/deepseek-chat-v3-0324:free

# Fallback providers (optional — leave blank to skip)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM Retry Configuration
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=2.0

# ---------------------------------------------------------------------------
# Embeddings — Local SBERT
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=local
SBERT_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
SENTENCE_TRANSFORMERS_HOME=./models_cache

# ---------------------------------------------------------------------------
# Feature Flags — disable heavy services for fast dev startup
# ---------------------------------------------------------------------------
ENABLE_EMBEDDINGS=false
ENABLE_REDIS=true

# ---------------------------------------------------------------------------
# Object Storage — local (dev) / S3 (staging/prod)
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=ats-resumes
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
AWS_REGION=us-east-1
S3_USE_SSL=false

# ---------------------------------------------------------------------------
# File Upload
# ---------------------------------------------------------------------------
FILE_MAX_SIZE_MB=10
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_FREE_ANALYSES_PER_DAY=5
RATE_LIMIT_PRO_ANALYSES_PER_DAY=50
RATE_LIMIT_REQUESTS_PER_MINUTE_FREE=10
RATE_LIMIT_REQUESTS_PER_MINUTE_PRO=60

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Analysis Cache
# ---------------------------------------------------------------------------
ANALYSIS_CACHE_TTL_SECONDS=86400
RESUME_PARSE_CACHE_TTL_SECONDS=604800
LOCK_TTL_SECONDS=600

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# ---------------------------------------------------------------------------
# Email (optional — for notifications)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@ats-platform.local

# ---------------------------------------------------------------------------
# ClamAV (optional — leave blank to skip malware scanning)
# ---------------------------------------------------------------------------
CLAMAV_HOST=
CLAMAV_PORT=3310

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
SENTRY_DSN=
