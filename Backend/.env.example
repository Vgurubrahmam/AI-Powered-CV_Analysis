# =============================================================================
#  ATS Platform — Environment Variables Reference
#  Copy to .env and fill in real values. Never commit .env to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development                        # development | staging | production
APP_URL=http://localhost:8000              # Used in LLM request headers & links
DEBUG=true                                 # Set false in production
SECRET_KEY=change-me-to-32-chars-random   # Used for signing cookies/sessions

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ats_user:ats_pass@localhost:5432/ats_db

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# LLM — OpenRouter (primary provider, OpenAI-compatible API)
# Get free API key at: https://openrouter.ai
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemma-3-27b-it:free
OPENROUTER_FAST_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_SMART_MODEL=deepseek/deepseek-chat-v3-0324:free

# Fallback providers (optional — leave blank to skip)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM Retry Configuration
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=2.0

# ---------------------------------------------------------------------------
# Embeddings — Local SBERT
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=local                   # local | openai
SBERT_MODEL_NAME=all-mpnet-base-v2         # Loaded from HuggingFace cache
EMBEDDING_DIMENSION=768                    # 768 for all-mpnet-base-v2

# ---------------------------------------------------------------------------
# Object Storage — MinIO (local, S3-compatible)
# ---------------------------------------------------------------------------
S3_ENDPOINT_URL=http://localhost:9000      # MinIO endpoint (blank for real AWS S3)
S3_BUCKET_NAME=ats-resumes
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
AWS_REGION=us-east-1
S3_USE_SSL=false                           # Set true for production S3

# ---------------------------------------------------------------------------
# File Upload
# ---------------------------------------------------------------------------
FILE_MAX_SIZE_MB=10
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_FREE_ANALYSES_PER_DAY=5
RATE_LIMIT_PRO_ANALYSES_PER_DAY=50
RATE_LIMIT_REQUESTS_PER_MINUTE_FREE=10
RATE_LIMIT_REQUESTS_PER_MINUTE_PRO=60

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Analysis Cache
# ---------------------------------------------------------------------------
ANALYSIS_CACHE_TTL_SECONDS=86400          # 24 hours
RESUME_PARSE_CACHE_TTL_SECONDS=604800     # 7 days
LOCK_TTL_SECONDS=600                       # 10 min max lock for analysis

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SOFT_TIME_LIMIT=300           # 5 min soft limit
CELERY_TASK_TIME_LIMIT=600               # 10 min hard limit

# ---------------------------------------------------------------------------
# Email (optional — for notifications)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@ats-platform.local

# ---------------------------------------------------------------------------
# ClamAV (optional — leave blank to skip malware scanning)
# ---------------------------------------------------------------------------
CLAMAV_HOST=
CLAMAV_PORT=3310

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
SENTRY_DSN=                               # Optional Sentry error tracking
