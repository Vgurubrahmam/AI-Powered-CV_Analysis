# =============================================================================
#  Backend .gitignore — Python / FastAPI / Celery
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ── Environment variables (secrets) ──────────────────────────────────────────
.env
.env.*
!.env.example

# ── Distribution / Packaging ─────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
*.whl
*.tar.gz
sdist/
wheels/

# ── Testing / Coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# ── MyPy / Type checking ─────────────────────────────────────────────────────
.mypy_cache/
.pytype/
.pyre/

# ── Celery ────────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid

# ── Database migrations (auto-generated) ─────────────────────────────────────
# Keep migration files — only ignore temp stamps
*.pyc

# ── Local file storage (dev uploads, root-level only) ────────────────────────
/storage/

# ── SBERT / ML model cache ───────────────────────────────────────────────────
models_cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Temp / scratch scripts ───────────────────────────────────────────────────
_test_*.py
_fix_*.py
_check_*.py
migrate_resumes.py

# ── Docker (local) ───────────────────────────────────────────────────────────
*.pid

# ── Jupyter / IPython ────────────────────────────────────────────────────────
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── Node (if any JS tooling) ─────────────────────────────────────────────────
node_modules/
