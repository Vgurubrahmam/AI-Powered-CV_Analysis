# =============================================================================
#  Frontend .gitignore — React / Vite / TypeScript
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
.output/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Testing / Coverage ───────────────────────────────────────────────────────
coverage/
*.lcov

# ── TypeScript cache ─────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Vite ──────────────────────────────────────────────────────────────────────
*.local

# ── Storybook ─────────────────────────────────────────────────────────────────
storybook-static/

# ── Misc ──────────────────────────────────────────────────────────────────────
.eslintcache
.stylelintcache
